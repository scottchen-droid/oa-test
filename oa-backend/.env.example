# App
NODE_ENV=development
PORT=8080

# Database (GCP Cloud SQL)
DATABASE_URL="postgresql://postgres:password@35.229.147.245:5432/oa?schema=public&sslmode=require"

# JWT
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_REFRESH_SECRET=change-this-to-another-long-random-string-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# GCP
GCP_PROJECT_ID=your-gcp-project-id
GCS_BUCKET_NAME=oa-attachments

# Encryption key for sensitive fields (must be exactly 32 chars)
ENCRYPTION_KEY=12345678901234567890123456789012

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM="OA System <noreply@example.com>"

# Frontend URL (for password reset email links)
FRONTEND_URL=http://localhost:5173

# CORS
CORS_ORIGIN=http://localhost:5173
